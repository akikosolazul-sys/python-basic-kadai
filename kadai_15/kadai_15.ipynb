        "class Human:\n",
        "  def __init__(self,name,age):\n",
        "    self.name = name\n",
        "    self.age = age\n",
        "\n",
        "  def printinfo(self):\n",
        "    print(\"name:\",self.name)\n",
        "    print(\"age:\",self.age)\n",
        "\n",
        "h=Human(\"Tomas\",25)\n",
        "h.printinfo()"
