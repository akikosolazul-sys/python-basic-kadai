        "rem3 = var % 3\n",
        "rem5 = var % 5\n",
        "if rem3 == 0 and rem5 != 0:\n",
        "  print(\"Fizz\")\n",
        "elif rem3 != 0 and rem5 == 0:\n",
        "  print(\"Buzz\")\n",
